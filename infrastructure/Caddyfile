# LobeChat — flush_interval -1 disables response buffering so SSE chat tokens
# stream to the browser incrementally (Appendix A.4: streaming validation item).
alicenl-lobechat.duckdns.org {
	reverse_proxy localhost:47000 {
		flush_interval -1
	}
}

# Casdoor SSO — served on the lobechat hostname at :8443 (reuses the working
# lobechat cert). DuckDNS CAA lookups intermittently timed out when issuing a
# separate cert for the casdoor subdomain, so we avoid needing one. The OIDC
# issuer is https://alicenl-lobechat.duckdns.org:8443.
alicenl-lobechat.duckdns.org:8443 {
	reverse_proxy localhost:47002
}

# (Optional) casdoor subdomain — kept for reference; not required since Casdoor
# is reached via :8443 above. Will only get a cert if DuckDNS CAA cooperates.
alicenl-casdoor.duckdns.org {
	reverse_proxy localhost:47002
}

# MinIO S3 API. Host header is preserved upstream so SigV4 presigned-URL
# signatures (signed by lobe-chat for this exact host) validate at MinIO.
alicenl-minio.duckdns.org {
	reverse_proxy localhost:47005
}
